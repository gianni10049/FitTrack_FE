# GraphQL (Apollo) — default allineati al backend template (porta 4000, path /graphql)
NEXT_PUBLIC_GRAPHQL_HTTP_URL=http://localhost:4000/graphql
NEXT_PUBLIC_GRAPHQL_WS_URL=ws://localhost:4000/graphql

# Branding (titolo/metadata in layout)
# NEXT_PUBLIC_APP_NAME=FitTrack

# Dev: log errori GraphQL su console (default: attivo in development). Imposta a 0 per disattivare.
# NEXT_PUBLIC_GRAPHQL_DEBUG_ERRORS=0

# Opzionale: base URL REST se aggiungi chiamate fetch al backend
# NEXT_PUBLIC_API_URL=http://localhost:4000
